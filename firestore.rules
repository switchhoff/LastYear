/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid prototyping and ease of access while maintaining
 * a baseline level of authorization security. It enforces user-ownership for
 * user profiles and allows open access to shared memories. Data validation is
 * minimized to facilitate quick iteration.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the owning user.
 * - /memories/{memoryId}: Stores shared memories, accessible by any
 *   authenticated user.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Memories are publicly readable and writable by authenticated users.
 * - Data validation is relaxed to enable rapid schema changes. Only ownership
 *   and relational integrity are validated.
 *
 * Denormalization for Authorization:
 *   Not applicable in this simple ruleset.
 *
 * Structural Segregation:
 *   Uses separate collections for user profiles (private) and shared memories
 *   (public).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles. Only the
     *   authenticated user can read, create, update, or delete their own
     *   profile.
     * @path /users/{userId}
     * @allow (create) - User 'user_abc' creates their own profile with
     *   userId: 'user_abc'.
     * @allow (get) - User 'user_abc' reads their own profile.
     * @allow (update) - User 'user_abc' updates their own profile.
     * @allow (delete) - User 'user_abc' deletes their own profile.
     * @deny (create) - User 'user_xyz' attempts to create a profile with
     *   userId: 'user_abc'.
     * @deny (get) - User 'user_xyz' attempts to read user 'user_abc' profile.
     * @deny (update) - User 'user_xyz' attempts to update user 'user_abc'
     *   profile.
     * @deny (delete) - User 'user_xyz' attempts to delete user 'user_abc'
     *   profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Allow a user to create their own profile if the userId matches their
      // auth UID.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      // Allow a user to get their own profile.
      allow get: if isSignedIn() && isOwner(userId);
      // Allow a user to list their own profile.
      allow list: if false;
      // Allow a user to update their own profile if it exists and they are the
      // owner. Enforce immutability of the user ID.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      // Allow a user to delete their own profile if it exists and they are the
      // owner.
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read and write shared
     *   memories.
     * @path /memories/{memoryId}
     * @allow (create) - Any authenticated user can create a memory.
     * @allow (get) - Any user can read any memory
     * @allow (update) - Any authenticated user can update a memory.
     * @allow (delete) - Any authenticated user can delete a memory.
     * @allow (list) - Any user can list memories.
     * @principle Allows public read access with authenticated write access.
     */
    match /memories/{memoryId} {
      allow create: if isSignedIn();
      allow get: if true;
      allow list: if true;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the request is made by the owner of the
  // document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the request is made by the owner of an
    // existing document.
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
}