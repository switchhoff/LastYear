/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes a flexible data structure while enforcing strict user-based authorization.
 * Data validation is minimized to allow for rapid prototyping, focusing instead on secure access control.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the owning user.
 * - /memories/{memoryId}: Stores public memories, readable by any authenticated user.
 * - /memories/{memoryId}/reactions/{userId}: Stores user reactions to memories, accessible only by the reacting user.
 * - /memories/{memoryId}/chat_messages/{messageId}: Stores chat messages for memories, accessible by any authenticated user.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Public read access is granted to the /memories collection to foster content sharing.
 * - Strict ownership is enforced for user profiles and memory reactions.
 * - No role-based access control is implemented in this prototype.
 *
 * Denormalization for Authorization:
 * - The `UserMemoryReaction` documents are located at `/memories/{memoryId}/reactions/{userId}`,
 *   with the document ID being the `userId`. This avoids the need for `get()` calls to verify ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @returns {boolean} - True if the user is signed in and the UID matches, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @returns {boolean} - True if the user is signed in, the UID matches, and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rule for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) - Allow a user to create their own profile if the userId matches their auth UID.
     * @allow (get, update, delete) - Allow a user to read, update, and delete their own profile if the userId matches their auth UID.
     * @deny (create) - Deny a user from creating a profile with a userId that does not match their auth UID.
     * @deny (get, update, delete) - Deny a user from reading, updating, or deleting a profile that does not belong to them.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for the /memories/{memoryId} collection.
     * @path /memories/{memoryId}
     * @allow (get, list) - Allow any authenticated user to read memories.
     * @allow (create, update, delete) - Allow any authenticated user to create, update or delete memories.
     * @deny (create, update, delete) - No write operations are explicitly denied.
     * @principle Allows public read access to memories for content sharing.
     */
    match /memories/{memoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rule for the /memories/{memoryId}/reactions/{userId} collection.
     * @path /memories/{memoryId}/reactions/{userId}
     * @allow (get) - Allow a user to read their own reaction to a memory if the userId matches their auth UID.
     * @allow (create) - Allow a user to create their own reaction to a memory if the userId matches their auth UID.
     * @allow (update, delete) - Allow a user to update and delete their own reaction to a memory if the userId matches their auth UID.
     * @deny (get, create, update, delete) - Deny a user from accessing reactions that do not belong to them.
     * @principle Enforces document ownership for memory reactions.
     */
    match /memories/{memoryId}/reactions/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for the /memories/{memoryId}/chat_messages/{messageId} collection.
     * @path /memories/{memoryId}/chat_messages/{messageId}
     * @allow (get, list) - Allow any authenticated user to read chat messages.
     * @allow (create, update, delete) - Allow any authenticated user to create, update, or delete chat messages.
     * @deny (create, update, delete) - No write operations are explicitly denied.
     * @principle Allows public read and write access to chat messages within a memory.
     */
    match /memories/{memoryId}/chat_messages/{messageId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}