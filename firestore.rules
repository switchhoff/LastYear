/**
 * @fileoverview Firestore Security Rules for the memories application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and open access with ownership control for shared memories.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, accessible only by the user themselves.
 * - /memories/{memoryId}: Stores shared memories, reactions, and chat. Publicly readable but writes are restricted to authenticated users.
 * - /userMemories/{memoryId}/users/{userId}: Stores individual user memories, accessible only by the user who created the memory.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - The /memories collection is publicly readable.
 *
 * Denormalization for Authorization:
 * - The /memories/{memoryId} documents do not have an explicit `ownerId` field. Instead, we will rely on the `request.auth.uid` to control access for writes. A memory can be created by any authenticated user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles.
     * @path /users/{userId}
     * @allow (create) If the user's ID matches the authenticated user's UID.
     * @allow (get, update, delete) If the user's ID matches the authenticated user's UID and the document exists.
     * @deny (list) Listing users is not allowed.
     * @deny (create, update, delete) If the user's ID does not match the authenticated user's UID.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in and is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the user is signed in and is the owner of the document and it exists.
      function isExistingOwner(userId) {
        return isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId));
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to shared memories.
     * @path /memories/{memoryId}
     * @allow (get, list) Any authenticated user can read shared memories.
     * @allow (create) Any authenticated user can create a shared memory.
     * @allow (update, delete) Only the user who created the memory can update or delete it.
     * @deny (create, update, delete) if not authenticated.
     * @principle Allows public read access but restricts writes to authenticated users.
     */
    match /memories/{memoryId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return get(/databases/$(database)/documents/memories/$(memoryId)).data.owner == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner();
      allow delete: if isSignedIn() && isOwner();
    }

    /**
     * @description Manages access to individual user memories within a shared memory.
     * @path /userMemories/{memoryId}/users/{userId}
     * @allow (create) If the user's ID matches the authenticated user's UID.
     * @allow (get, update, delete) If the user's ID matches the authenticated user's UID and the document exists.
     * @deny (list) Listing user memories is not allowed.
     * @deny (create, update, delete) If the user's ID does not match the authenticated user's UID.
     * @principle Enforces strict user ownership for individual memory entries.
     */
    match /userMemories/{memoryId}/users/{userId} {
      // Helper function to check if the user is signed in and is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the user is signed in and is the owner of the document and it exists.
      function isExistingOwner(userId) {
        return isOwner(userId) && existsAfter(/databases/$(database)/documents/userMemories/$(memoryId)/users/$(userId));
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}