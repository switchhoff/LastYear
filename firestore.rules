/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid prototyping by granting broad access to all authenticated users.
 * It's designed to be permissive and allow any logged-in user to read and write any data.
 *
 * Data Structure:
 * - Users are stored in `/users/{userId}`.
 * - Memories are stored in `/memories/{memoryId}`.
 *
 * Key Security Decisions:
 * - Any authenticated user can access any data.
 * - No data shape validation is enforced for speed of iteration.
 * - This is a PROTOTYPE and is NOT suitable for production use.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to manage user profiles.
     * @path /users/{userId}
     * @allow (create) User with matching userId can create their profile.
     * @allow (get, list, update, delete) Any authenticated user can get, list, update, and delete user profiles.
     * @deny (none) No restrictions are enforced beyond authentication.
     * @principle Allows any authenticated user to access any user profile.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to manage memories.
     * @path /memories/{memoryId}
     * @allow (create) Any authenticated user can create a memory.
     * @allow (get, list, update, delete) Any authenticated user can get, list, update, and delete any memory.
     * @deny (none) No restrictions are enforced beyond authentication.
     * @principle Allows any authenticated user to access any memory.
     */
    match /memories/{memoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}