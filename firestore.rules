/**
 * @fileoverview Firestore Security Rules for the Memories application.
 *
 * Core Philosophy:
 * This ruleset prioritizes ease of collaboration and data sharing. All authenticated users can read and contribute to the "memories" collection.
 * User-specific data (profiles) is restricted to the owning user.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only to the owning user.
 * - /memories/{memoryId}: Stores shared memories. Any authenticated user can read and contribute (add sentences, reactions, chat messages).
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Memories are designed for open collaboration; all authenticated users can contribute.
 *
 * Denormalization for Authorization:
 * The `memories/{memoryId}` documents contain all the necessary information for authorization. No additional `get()` calls are needed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Allows a user to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) - User with UID "user123" can create a profile at /users/user123.
     * @allow (get) - User with UID "user123" can read their profile at /users/user123.
     * @allow (update) - User with UID "user123" can update their profile at /users/user123.
     * @allow (delete) - User with UID "user123" can delete their profile at /users/user123.
     * @deny (create) - User with UID "user456" cannot create a profile at /users/user123.
     * @deny (get) - User with UID "user456" cannot read profile /users/user123.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read and contribute to shared memories.
     * @path /memories/{memoryId}
     * @allow (get) - Any authenticated user can read a memory.
     * @allow (list) - Any authenticated user can list memories.
     * @allow (create) - Any authenticated user can create a memory.
     * @allow (update) - Any authenticated user can update a memory (e.g., add a sentence).
     * @allow (delete) - Any authenticated user can delete a memory.
     * @deny (update) - An unauthenticated user cannot modify a memory.
     * @principle Allows open collaboration on shared memories.
     */
    match /memories/{memoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
