/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset prioritizes open access to memories while enforcing user-ownership
 * for user profiles.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles. Access is restricted to
 *   the owner of the profile.
 * - /memories/{memoryId}: Stores shared memories, accessible for reading and
 *   writing by any authenticated user.
 *
 * Key Security Decisions:
 * - Memories are publicly accessible for both read and write operations, allowing
 *   any authenticated user to view and contribute.
 * - User profiles are strictly controlled, allowing only the owning user to
 *   modify their data.
 * - The rules do not currently enforce any schema validation beyond ownership
 *   and authenticated user checks to allow rapid prototyping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to memory documents for any authenticated user.
     * @path /memories/{memoryId}
     * @allow (get, list) Any authenticated user can read memories.
     * @allow (create) Any authenticated user can create memories.
     * @allow (update) Any authenticated user can update memories.
     * @allow (delete) Any authenticated user can delete memories.
     * @deny (create, update, delete) Operations that are not authenticated.
     * @principle Allows any authenticated user to perform CRUD operations on memories.
     */
    match /memories/{memoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get, list) Only the owner can read.
     * @allow (create) The user can create their own profile (self-creation).
     * @allow (update, delete) Only the owner can modify or delete.
     * @deny (create) If the user tries to create a profile with a mismatched userId.
     * @deny (update, delete) If the user is not the owner or the document does not exist.
     * @principle Enforces strict user-ownership for profile management.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}