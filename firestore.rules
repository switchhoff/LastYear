/**
 * @file Firestore Security Rules
 * @description This ruleset prioritizes developer iteration speed and enforces a basic level of authorization.
 *
 * Core Philosophy:
 * Data access is broadly open for logged-in users, focusing on enabling rapid prototyping.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles.
 * - /memories/{memoryId}: Stores shared memories.
 *
 * Key Security Decisions:
 * - User listing is implicitly disabled as there are no rules allowing `list` on `/users`.
 * - Data validation is minimal to accelerate development.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles. Anyone can access the user.
     * @path /users/{userId}
     * @allow (create, update, delete) - Any user can create, update, and delete.
     * @allow (get, list) - Any user can get and list
     * @deny (none) - No requests are denied.
     * @principle Open access for user data to facilitate development.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    /**
     * @description Controls access to shared memories.
     * @path /memories/{memoryId}
     * @allow (create, update, delete) - Authenticated users can create, update, and delete memories.
     * @allow (get, list) - Anyone can read the memories.
     * @deny (none) - No requests are denied.
     * @principle: Authenticated users have full access to memories for prototyping.
     */
    match /memories/{memoryId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

  }

  function isSignedIn() {
    return request.auth != null;
  }
}